# Web UI uses Stockfish (UCI). Use a full path if the engine is not on PATH.
CHESS_STOCKFISH_PATH=stockfish/stockfish-windows-x86-64-avx2.exe

# Stronger analysis (optional):
# CHESS_STOCKFISH_THREADS=4
# CHESS_STOCKFISH_HASH_MB=256
# CHESS_ANALYSIS_MOVETIME_MS=400
# CHESS_ANALYSIS_SIMS_DIVISOR=2

# Play-mode search depth (default 14)
# CHESS_STOCKFISH_DEPTH=14

FLASK_DEBUG=1
PORT=5000
